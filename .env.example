# Database
POSTGRES_DB=statica
POSTGRES_USER=statica
POSTGRES_PASSWORD=statica
POSTGRES_PORT=5432
DATABASE_URL=postgres://statica:statica@localhost:5432/statica?sslmode=disable

# Server
PORT=8080
JWT_SECRET=change-me-in-production
STATICA_SERVER_URL=ws://localhost:8080/ws
STATICA_APP_URL=http://localhost:3000
STATICA_DAEMON_CONFIG=
STATICA_WORKSPACE_ID=
STATICA_DAEMON_ID=
STATICA_DAEMON_DEVICE_NAME=
STATICA_DAEMON_POLL_INTERVAL=3s
STATICA_DAEMON_HEARTBEAT_INTERVAL=15s
STATICA_CODEX_PATH=codex
STATICA_CODEX_MODEL=
STATICA_CODEX_WORKDIR=
STATICA_CODEX_TIMEOUT=20m

# Email (Resend)
# For local/dev use, leave RESEND_API_KEY empty — codes print to stdout, and master code 888888 works.
# For production, set your Resend API key and change RESEND_FROM_EMAIL to a domain verified in your Resend account.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@statica.ai

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# S3 / CloudFront
S3_BUCKET=
S3_REGION=us-west-2
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_SECRET=statica/cloudfront-signing-key
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_DOMAIN=
COOKIE_DOMAIN=



# Security
# Comma-separated list of allowed origins for CORS and WebSocket connections.
# Defaults to localhost dev origins when unset.
# Example: ALLOWED_ORIGINS=https://app.statica.ai,https://staging.statica.ai
ALLOWED_ORIGINS=

# Frontend
FRONTEND_PORT=3000
FRONTEND_ORIGIN=http://localhost:3000
# Leave empty — auto-derived from page origin in browser, set by Makefile for local dev.
# Only set explicitly if frontend and backend are on different domains.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
